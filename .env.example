# vehicle-safety-agent — environment configuration (example).
# Copy to .env and fill in real values. Never commit your real .env.
#
# NOTE: These variables are declared here as stable targets. On Day 1 (scaffold)
# nothing reads them yet — enforcement lands with the agent core.

# ---- Anthropic API ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ---- Rate limits ----
# Keep the agent from hammering the Anthropic API or upstream data sources.
MAX_REQUESTS_PER_MINUTE=60
MAX_CONCURRENT_INVESTIGATIONS=4

# ---- Cost caps ----
# Hard stops so a runaway investigation can't burn the budget.
MAX_TOKENS_PER_RUN=200000
MAX_COST_USD_PER_RUN=1.00
DAILY_COST_CAP_USD=25.00
