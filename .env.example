# vehicle-safety-agent — environment configuration (example).
# Copy to .env and fill in real values. Never commit your real .env.
#
# Variables read by app/core/config.py::Settings are marked [live]; the rest are
# declared targets for controls still on the roadmap.

# ---- Anthropic API ----
ANTHROPIC_API_KEY=                        # [live] required for real runs
ANTHROPIC_MODEL=claude-sonnet-4-6         # [live] agent + judge model

# ---- Loop bounds ----
MAX_TOOL_ROUNDS=6                          # [live] tool-call rounds before forced final answer
MAX_OUTPUT_TOKENS=2048                     # [live] per Anthropic response

# ---- Rate limits ----
RATE_LIMIT=10/minute                       # [live] per client IP (slowapi)
MAX_CONCURRENT_INVESTIGATIONS=4            # roadmap

# ---- Cost caps ----
# Hard stops so a runaway investigation can't burn the budget.
MAX_COST_USD_PER_RUN=1.00                  # [live] hard per-request cap
MAX_TOKENS_PER_RUN=200000                  # roadmap
DAILY_COST_CAP_USD=25.00                   # roadmap
