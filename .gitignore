# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
*.log

# ---- uv ----
# Lockfile (uv.lock) is committed; caches are not.
.uv/

# ---- Node / frontend ----
node_modules/
.next/
.turbo/
out/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- Env / secrets (Standing Rule 1 — never commit credentials) ----
.env
.env.*
*.env
!.env.example

# Keys, certs, tokens — nothing that can carry a credential.
*.key
*.pem
*.p12
*.pfx
*.crt
*.token
*.pat
*secret*
*credential*
.netrc
id_rsa*

# ---- Editor / OS ----
.DS_Store
.idea/
.vscode/
*.swp

# Local-only working context — not published.
CLAUDE.md
